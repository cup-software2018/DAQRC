#
# DAQ Server where tcb is supposed to be running
#
kDAQSERVER_IP = 'localhost'  # Update with actual DAQ IP
kDAQSERVER_PORT = 7100       # Update with actual DAQ Port
kDAQSERVER_ADDR = 'tcp://%s:%d' % (kDAQSERVER_IP, kDAQSERVER_PORT)

# If RC is running on same server with DAQ
kISREMOTEDAQ = False

# Directories at DAQ server
kONLDAQ_DIR = '/opt/cupdaq'  # Set to actual directory
kRAWDATA_DIR = '/data'       # Set to actual directory

# Run catalog db file should be in same server with RC
kRUNCATALOGDBFILE = 'runcatalog.db'
kDEFAULTCONFIGDIR = './config'

# Add more run types
kRUNTYPELIST = ['', 'physics', 'calibration', 'test']

kOUTPUTFILEFORMAT = 'hdf5' # hdf5 or root

# ===========================================================
# Do not modify from here!!! (Updated for DAQ Monitor refactoring)
# ===========================================================

# DAQ Monitor ZMQ Server Address
kMONITORIPADDR = 'localhost'
kMONITORPORT = 7030
kMONITOR_ADDR = 'tcp://%s:%d' % (kMONITORIPADDR, kMONITORPORT)

kEXESCRIPT = 'executedaq.sh'
kMESSLEN = 32

# Commands (Updated for JSON payload)
kCONFIGRUN = "kCONFIGRUN"
kSTARTRUN = "kSTARTRUN"
kENDRUN = "kENDRUN"
kEXIT = "kEXIT"
kQUERYDAQSTATUS = "kQUERYDAQSTATUS"
kQUERYRUNINFO = "kQUERYRUNINFO"
kQUERYTRGINFO = "kQUERYTRGINFO"
kQUERYMONITOR = "kQUERYMONITOR"

# RUN Status
kDOWN = 0
kBOOTED = 1
kCONFIGURED = 2
kRUNNING = 3
kRUNENDED = 4
kPROCENDED = 5
kWARNING = 6
kERROR = 7

kDAQSTATE = ['Down', 'Booted', 'Configured',
             'Running', 'RunEnd', 'ProcEnd', 'Warning', 'Error']